# Neon pooled connection string used by Prisma Client at runtime.
# For Neon, this is typically the endpoint with pooler enabled.
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"

# Direct Neon connection string used only for migrations.
# Prisma migrate should target a direct (non-pooler) database URL.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Public deterministic seed used to generate the MVP world.
NEXT_PUBLIC_WORLD_SEED="coinage-mvp-seed"

# Public number of planets generated in the MVP world.
NEXT_PUBLIC_WORLD_PLANET_COUNT="128"
